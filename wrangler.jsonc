{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "tokenomic",
  "compatibility_date": "2026-04-18",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "_site"
  },
  "build": {
    "command": "bundle exec jekyll build"
  }
}
