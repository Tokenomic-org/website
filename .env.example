# Tokenomic smart-contract deployment
# Copy to .env and fill in real values. Never commit .env.

# RPC endpoints
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: your own Cloudflare Ethereum/Base gateway (from Prompt 3)
CLOUDFLARE_ETH_GATEWAY=

# Deployer wallet (use a fresh key with only enough ETH for gas)
PRIVATE_KEY=0xyour_deployer_private_key_here

# USDC contract (defaults are baked into scripts/deploy.js):
#   Base mainnet : 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
#   Base Sepolia : 0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS=

# Basescan (or Etherscan multichain) API key for verification
BASESCAN_API_KEY=

# ---------------------------------------------------------------------------
# Phase 0 — wallet stack + SIWE (read by `npm run build:web3` and the workers)
# ---------------------------------------------------------------------------
# WalletConnect Cloud project id (https://cloud.walletconnect.com).
# Required so the `Connect Wallet` modal can show the WC QR option.
WC_PROJECT_ID=

# Public JSON-RPC endpoints used by the bundled wagmi config.
# BASE_RPC_URL / BASE_SEPOLIA_RPC_URL above already cover the `web3-worker`
# proxy; these two repeat them for the browser bundle. Defaults are baked in
# so leaving them blank still produces a working build.
# BASE_RPC_URL=https://mainnet.base.org
# BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Treasury wallet that receives the platform fee on USDC payouts. Read by the
# Hardhat deploy scripts and surfaced to the api-worker via PLATFORM_TREASURY.
PLATFORM_TREASURY=

# SIWE cookie HMAC key. If left blank, the api-worker falls back to JWT_SECRET.
# Set with: wrangler secret put SIWE_SECRET --env api-worker
SIWE_SECRET=

# JWT signing secret for the legacy /api/auth/login flow.
# Set with: wrangler secret put JWT_SECRET --env api-worker
JWT_SECRET=

# SIWE domain(s) accepted in the signed message header. SIWE_DOMAIN is the
# canonical/default; SIWE_DOMAINS is an optional comma-separated allowlist for
# www/staging hosts that should verify against the same worker. Example:
#   SIWE_DOMAIN=tokenomic.org
#   SIWE_DOMAINS=tokenomic.org,www.tokenomic.org,staging.tokenomic.org
# Each entry must match exactly (no wildcards). Frontends can pin the message
# domain by setting window.TOKENOMIC_SIWE_DOMAIN before siwe-client.js runs.
SIWE_DOMAIN=
SIWE_DOMAINS=
# Comma-separated first-party origins allowed to make credentialed (cookie)
# requests to the api-worker. Defaults to tokenomic.org + localhost:5000.
# Add Replit dev URLs (https://*.replit.app, https://<id>-00-*.<region>.replit.dev)
# or staging Pages URLs explicitly here — never use bare *.pages.dev / *.workers.dev
# wildcards in production because those are multi-tenant.
ALLOWED_ORIGINS=

# ---------------------------------------------------------------------------
# Express dashboard (server.js) admin login. Both must be set; if either is
# blank the /api/admin/login route refuses to issue a session token.
# ---------------------------------------------------------------------------
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Postgres connection string for the local Express dashboard.
DATABASE_URL=
# Personal access token used by server.js to mirror communities/courses to
# GitHub. Scope: `repo` (private + public).
GITHUB_PERSONAL_ACCESS_TOKEN=
