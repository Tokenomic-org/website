# =============================================================================
# Tokenomic — local development env template
# =============================================================================
# Copy to `.env` and fill in real values. `.env` is in .gitignore — never commit
# it. In Replit, prefer the Secrets pane (lock icon) over editing this file.
#
# This file covers ONLY variables consumed on a developer machine:
#   - server.js              (the local Express dashboard)
#   - hardhat.config.js      (contract deploys/tests)
#   - scripts/*.{js,mjs}     (deploy + flow scripts)
#   - npm run build:web3     (esbuild --define injections, public values only)
#
# Production runtime secrets (JWT_SECRET, CF_API_TOKEN, OAUTH_*, INVITE_HMAC_KEY,
# TURNSTILE_SECRET_KEY, MAIL_DKIM_PRIVATE_KEY, OAUTH_TOKEN_ENC_KEY, etc.) live on
# Cloudflare — set them with `wrangler secret put <NAME> --env api-worker`.
# See SECRETS.md for the full classification table and step-by-step instructions.
# =============================================================================

# -----------------------------------------------------------------------------
# Hardhat / contract deploys (scripts/deploy.js, hardhat.config.js)
# -----------------------------------------------------------------------------
PRIVATE_KEY=0xyour_deployer_private_key_here   # use a FRESH key with only gas ETH
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
CLOUDFLARE_ETH_GATEWAY=
USDC_ADDRESS=                                  # leave blank to use the per-chain default
SPLIT_MAIN_ADDRESS=                            # leave blank to use the per-chain default
PLATFORM_TREASURY=                             # defaults to deployer.address
ADMIN_ADDRESS=                                 # defaults to deployer.address
SUBSCRIPTION_PRICE_USDC=9990000                # 9.99 USDC (6 decimals)
CONFIRM_MAINNET=                               # set to "1" to allow chainId 8453 deploys
BASESCAN_API_KEY=                              # for `npx hardhat verify`

# -----------------------------------------------------------------------------
# npm run build:web3 — esbuild --define injections (public values, safe in browser)
# -----------------------------------------------------------------------------
WC_PROJECT_ID=                                 # https://cloud.walletconnect.com — optional

# -----------------------------------------------------------------------------
# server.js — local Express dashboard (Replit workspace only, NOT a Cloudflare Worker)
# -----------------------------------------------------------------------------
PORT=5000
ADMIN_EMAIL=                                   # both required, or /api/admin/login refuses
ADMIN_PASSWORD=
DATABASE_URL=                                  # postgres://… for the local Express dashboard
GITHUB_PERSONAL_ACCESS_TOKEN=                  # scope: repo — for community/course mirroring

# -----------------------------------------------------------------------------
# scripts/test-full-flow.js — end-to-end Anvil/Base smoke test
# -----------------------------------------------------------------------------
RPC_URL=http://127.0.0.1:8545
PRIVATE_KEYS=                                  # comma-separated test keys; defaults baked in

# =============================================================================
# DO NOT add Cloudflare runtime secrets here. They are NOT read by any local
# script — only by the deployed Workers via `c.env.*`. Set them with:
#
#   cd workers/api-worker
#   npx wrangler secret put JWT_SECRET
#   npx wrangler secret put CF_ACCOUNT_ID
#   npx wrangler secret put CF_API_TOKEN
#   npx wrangler secret put OAUTH_TOKEN_ENC_KEY
#   npx wrangler secret put INVITE_HMAC_KEY
#   …  (full list in SECRETS.md §1a)
# =============================================================================
